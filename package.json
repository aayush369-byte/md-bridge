{
  "name": "md-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "PDF and Markdown conversions exposed as a local web app. Heuristic, no AI.",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "apps/api/.venv/Scripts/python.exe -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000 --app-dir apps/api",
    "dev:web": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "test:api": "apps/api/.venv/Scripts/python.exe -m pytest apps/api/tests",
    "test:regression": "apps/api/.venv/Scripts/python.exe -m pytest tests",
    "test:web": "npm --prefix apps/web run test",
    "test:e2e": "npm --prefix apps/web run test:e2e",
    "test:all": "npm run test:api && npm run test:regression && npm run test:web && npm run test:e2e"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
